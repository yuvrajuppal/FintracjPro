generator client {
  provider = "prisma-client-js"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  paymentType String
  description String
  amount      Float
  date        DateTime
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user user @relation(fields: [userId], references: [uiid])
}

model user {
  uiid         String        @id
  email        String        @unique(map: "User_email_key")
  password     String
  fullName     String
  currency     String        @default("INR")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}
